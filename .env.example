# Environment variables for Skills Observatory

# Local SQLite (default)
DATABASE_URL=

# Production PostgreSQL (Railway / Docker / Neon)
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/skills_observatory"

# Cron protection for /api/cron/sync (Vercel sends: Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=

# --- Optional API keys (each unlocks an extra real data source) ---

# Adzuna (free tier at https://developer.adzuna.com) — South Africa job listings
# ADZUNA_APP_ID=""
# ADZUNA_APP_KEY=""

# Jooble — requires per-country African keys (a US key returns US towns like "Angola, NY")
# Register on each country site (e.g. ng.jooble.org, ke.jooble.org, za.jooble.org) then set:
# JOOBLE_COUNTRY_KEYS='[{"country":"Nigeria","host":"ng.jooble.org","key":"..."},{"country":"Kenya","host":"ke.jooble.org","key":"..."}]'

# ReliefWeb (free appname at https://apidoc.reliefweb.int/parameters#appname) — UN/NGO jobs across all of Africa
# RELIEFWEB_APPNAME=""

# Apify Africa jobs aggregator (BrighterMonday + Jobberman + Careers24 + MyJobMag at scale)
# APIFY_TOKEN=""
